    bool
    depends on HAVE_GPIO && !MACH_AVR
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_TRAJECTORY_PWM
    # Sampled PWM/DAC actuator backend (FD-0001 doc 04). Needs both
    # the trajectory segment core and a hard PWM output to sample onto.
    bool
    depends on WANT_TRAJECTORY && WANT_HARD_PWM
    default y
config WANT_TRAJECTORY_HIGHER_ORDER
    # Cubic (jerk) and quintic (jerk/snap/crackle) Bezier segments on
    # top of the quadratic core (FD-0001 doc 02 "Higher-order
    # segments"). Adds j/s/c coefficient fields and the exact chained
    # integration for them; a quadratic-only build is byte-identical
    # with this off.
    bool
    depends on WANT_TRAJECTORY
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_TRACE
    # Structured trace plane (Atlas / FD-0002 §3): a registered,
    # machine-time-stamped event channel rendered to human strings on
    # the host via the data dictionary. Near-zero cost when a
    # subsystem's level is off; the ring is host-allocated, so the
    # firmware footprint is just code plus a small per-subsystem level
    # array — designed to fit the constrained F072.
    bool
    depends on HAVE_GPIO
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_SYSCALL_API
    # Unified cross-family board syscall table (FD-0001 doc 13): one
    # versioned function-pointer surface, wrapping the existing board.h
    # primitives, that every port exposes identically. Additive and small.
    bool
    depends on HAVE_GPIO
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_TRIGGER_SOURCE
    bool
    depends on HAVE_GPIO_EDGE_TRIGGER
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_HEATER_HOLD
    bool
    depends on WANT_ADC
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_BOOTLOADER
    bool
    depends on HAVE_BOOTLOADER_REQUEST
    default y if !HAVE_LIMITED_CODE_SIZE
config WANT_SIGNED_IMAGES
    bool "Signed firmware images (Ed25519)"
    depends on WANT_BOOTLOADER
    default n
    help
        Verify an Ed25519 (RFC 8032) signature over the application
        image in the first-class bootloader before marking it valid or
        booting it (FD-0001 doc 11, "Signed images") - a second gate
        beyond the transport HMAC and the whole-image CRC. The signature
        covers exactly the bytes the CRC covers and is stored in the
        validity page; the public key is embedded in the bootloader
        (keys/helix_pubkey.h) and the private key never lives on the
        device.

        The Ed25519 + SHA-512 verify adds ~6 KiB of bootloader code, so
        it does not fit the 16 KiB bootloader budget of the smallest
        parts (STM32F072/G0B1); those targets build the CRC-only
        bootloader and this option has no effect there. The bootloader
        itself is built from src/boot_app with `make bootloader SIGNED=1`,
        which defines CONFIG_WANT_SIGNED_IMAGES for that build; this
        Kconfig symbol records the intent for the application build.
        Off by default: enabling it means every accepted image must be
        signed, so provision signing keys first.

# Built-in self test: the verification gates runnable live on the board
# (docs/Helix_Test_Plan.md; host side [helix_self_test]).
config WANT_SELF_TEST
    bool "Built-in self test commands (run_self_test)"
    default y if !HAVE_LIMITED_CODE_SIZE
    default n
    help
        Register run_self_test: on-demand, protocol-driven self tests
        that execute the software verification gates live on this board
        (wire CRC vector, timer monotonicity, RAM pattern, and the
        trajectory fixed-point kernel checked against host golden
        vectors). Used at connect by the host's [helix_self_test]
        module and as a field diagnostic via HELIX_SELF_TEST. Cheap,
        safe (touches no I/O, moves nothing), and bounded.

# DTLS-class authenticated session over the datagram transport (doc 07).
config WANT_DATAGRAM_SESSION
    bool "DTLS-class session over the UDP datagram transport"
    depends on NEED_UDP_CONSOLE || MACH_LINUX
    default n
    help
        Offer the intentproto secure session (session_sec.hpp) on top of
        the static-PSK datagram floor: HKDF per-session keys, epoch key
        rotation, per-board identity, and a replay window (auth-only).
        The board is the responder; a host that never opens a session
        keeps using the static-PSK path. Once negotiated, data traffic is
        pinned to the session to prevent downgrade. Requires a PSK. Pulls
        in the session + SHA-512 code, so it is code-size sensitive. Off
        by default.

config DATAGRAM_SESSION_ID
    string "Per-board identity carried in the session handshake"
    depends on WANT_DATAGRAM_SESSION
    default "helix-board"
    help
        A short (<= 24 char) name identifying this board to the host in
        the session handshake. Give each board a distinct id.

# Serial console framing v2 (BCH FEC) — a framing transform on the UART
# console (docs/Protocol_v2.md). Opt-in, code-size sensitive (pulls in the
# BCH codec). LIVE-tested in emulation (test/console_v2_live_test.py on
# linuxprocess); silicon UART bring-up pending. Off by default.
config WANT_CONSOLE_FRAMING_V2
    bool "Accept intentproto v2 (BCH) framing on the serial UART console"
    default n
    help
        Let the board accept intentproto v2 error-correcting (BCH) framing
        on its serial UART console in addition to legacy CRC framing, and
        reply in v2 once a v2 frame is seen. This is a framing transform:
        the inner stock v1 command block and its ARQ (seq/ack/retransmit)
        are preserved; only the wire framing changes. Meaningful only for a
        byte-stream UART console (USB CDC and CAN carry their own
        integrity). Pulls in the BCH codec, so it is code-size sensitive.
        The transform is live-tested with linuxprocess; physical UART
        signal-path validation remains part of board bring-up.

# Network transports (FD-0001 doc 07): the datagram console binding
# runs unchanged over Ethernet.  These are opt-in and code-size
# sensitive - default off everywhere, and never defaulted on for
# limited-code-size boards.
config WANT_ETHERNET_W5500
    bool "Support W5500 SPI Ethernet datagram console transport"
    depends on WANT_SPI
    default n
    help
        WIZnet W5500 hardwired TCP/IP controller as a UDP datagram
        console transport - the same intentproto binding used over
        WiFi, riding a wired link.  Works on any board with an SPI bus.
        See docs/Ethernet.md.  Compile-checked, not hardware-validated.

if WANT_ETHERNET_W5500
config W5500_SPI_RATE
    int "W5500 SPI clock rate (Hz)"
    default 8000000
config W5500_TRUST_NETWORK
    bool "Run the W5500 link unauthenticated (trust_network confession)"
    default n
config W5500_PSK
    string "Pre-shared key for datagram authentication"
    default ""
config CONSOLE_W5500
    bool "Route the MCU console over the W5500 link"
    default n
    help
        Make the W5500 the board's console transport: board
        console_sendf()/console_receive_buffer() route through the
        datagram glue (as esp32/main.c does for its lwIP socket) and
        the link is brought up at startup from the static
        configuration below.  Leave off to use the W5500 as a
        secondary transport configured at runtime by config_w5500.
if CONSOLE_W5500
config W5500_SPI_BUS
    int "W5500 SPI bus index"
    default 0
config W5500_CS_PIN
    int "W5500 chip-select pin, encoded as (port-'A')*16 + num (PA4=4)"
    default 4
config W5500_UDP_PORT
    int "W5500 UDP listen port"
    default 1234
config W5500_IP
    hex "Static IPv4 address (0xC0A800FE == 192.168.0.254)"
    default 0xC0A800FE
config W5500_NETMASK
    hex "Static IPv4 netmask"
    default 0xFFFFFF00
config W5500_GATEWAY
    hex "Static IPv4 gateway"
    default 0xC0A80001
endif # CONSOLE_W5500
endif # WANT_ETHERNET_W5500

# Native on-chip Ethernet MAC + external RMII PHY path (needs a
# software IP stack).  HAVE_ETH_MAC is set by ports with a built-in MAC.
config HAVE_ETH_MAC
    bool
config WANT_ETHERNET_RMII
    bool "Support native RMII Ethernet MAC datagram console (design seam)"
    depends on HAVE_ETH_MAC
    default n
    help
        Native on-chip Ethernet MAC driving an external RMII PHY.
        Ships the MAC/DMA descriptor-ring bring-up skeleton
        (stm32/eth_mac.c) and a minimal built-in UDP/IP/ARP responder
        (generic/nano_udp.c) as the pluggable IP layer; the MAC DMA
        bring-up is a clearly-marked TODO seam where lwIP or the
        built-in responder plugs in.  See docs/Ethernet.md.
config WANT_NANO_UDP
    bool
    default y if WANT_ETHERNET_RMII
# The datagram-console glue (generic/udp_console.c + the C++ intentproto
# codec) is shared by every network transport
config NEED_UDP_CONSOLE
    bool
    default y if WANT_ETHERNET_W5500 || WANT_ETHERNET_RMII

