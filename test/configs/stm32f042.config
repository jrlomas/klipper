# Base config file for STM32F042 ARM processor
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F042=y
CONFIG_WANT_SOFTWARE_I2C=n
CONFIG_WANT_LIS2DW=n
CONFIG_WANT_LDC1612=n
CONFIG_WANT_HX71X=n
CONFIG_WANT_ADS1220=n
CONFIG_WANT_ADS131M0X=n
CONFIG_WANT_TRIGGER_ANALOG=n
# Keep the 32KiB fixture representative without both legacy LCD stacks;
# HD44780 remains covered by the larger cross-target configurations.
CONFIG_WANT_HD44780=n
