# NUCLEO-F767ZI ST-LINK VCP bootstrap and clock-diagnostics image.
# The default board topology drives PH0 from the ST-LINK 8MHz MCO.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F767=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_8M=y
CONFIG_STM32_HSE_BYPASS=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_SERIAL_USART3_ALT_PD9_PD8=y
