# OpenAMS OAMS1 rev1.4.3 STM32F072 USB acquisition image.
# The board has a 16 MHz crystal and Katapult occupies the first 8 KiB.
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F072=y
CONFIG_STM32_FLASH_START_2000=y
CONFIG_STM32_CLOCK_REF_16M=y
CONFIG_STM32_USB_PA11_PA12=y
CONFIG_WANT_ADC_STREAM=y
