# FK723M1-ZGT6 USB-to-CAN-FD gateway smoke image.
#
# The board has no on-board CAN transceiver, so this target validates H723
# clock, USB, FDCAN, interrupt, and gateway initialization only.  PB8/PB9 must
# be connected through an external CAN-FD transceiver before using the bus.
# The board's 15MHz HSE is not a supported Klipper H7 reference selection, so
# use the internal HSI reference, as in the computation qualification target.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32H723=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_INTERNAL=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_USBCANBUS_PA11_PA12=y
CONFIG_HELIX_USB_CAN_COMPOSITE=y
CONFIG_STM32_CMENU_CANBUS_PB8_PB9=y
CONFIG_CANBUS_FREQUENCY=1000000
CONFIG_CANBUS_FD=y
CONFIG_CANBUS_DATA_FREQUENCY=8000000
CONFIG_CANBUS_TRANSCEIVER_MAX_DATA_RATE=8000000
