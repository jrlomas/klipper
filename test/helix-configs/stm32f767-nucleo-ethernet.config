# NUCLEO-F767ZI focused RMII Ethernet protocol qualification image.
#
# The board routes the ST-LINK 8MHz MCO to HSE and the LAN8742A uses
# non-default transmit pins. DHCP is enabled for normal lab use; the static
# address is its bounded fallback on the current 192.168.1.0/24 test LAN.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F767=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_8M=y
CONFIG_STM32_HSE_BYPASS=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_ETHERNET_RMII=y
CONFIG_RMII_TX_EN_PIN=107
CONFIG_RMII_TXD0_PIN=109
CONFIG_RMII_TXD1_PIN=29
CONFIG_RMII_DHCP=y
CONFIG_RMII_IP=0xC0A801FA
CONFIG_RMII_NETMASK=0xFFFFFF00
CONFIG_RMII_GATEWAY=0xC0A80101
CONFIG_RMII_UDP_PORT=41415
CONFIG_RMII_PSK="nucleo-f767-ethernet-qualification"
CONFIG_WANT_DATAGRAM_SESSION=y
CONFIG_DATAGRAM_SESSION_ID="f767-ethernet-qual"
CONFIG_DMA_POOL_SIZE=16384
