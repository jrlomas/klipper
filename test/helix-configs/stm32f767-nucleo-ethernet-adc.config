# NUCLEO-F767ZI simultaneous RMII Ethernet and ADC DMA qualification image.
# ST-LINK MCO supplies the board's 8MHz HSE reference.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32F767=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_8M=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_ETHERNET_RMII=y
CONFIG_RMII_PSK="ci-rmii-adc-pre-shared-key"
CONFIG_WANT_DATAGRAM_SESSION=y
CONFIG_DATAGRAM_SESSION_ID="stm32f767-rmii-adc-ci"
CONFIG_WANT_ADC_STREAM=y
CONFIG_DMA_POOL_SIZE=16384
CONFIG_ADC_PROFILE=y
