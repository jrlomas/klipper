# FK723M1-ZGT6 computation-only HELIX qualification image.
# The board has a 15MHz HSE, which Klipper does not currently offer as a
# selectable H7 reference, so use the supported internal HSI reference.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32H723=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_INTERNAL=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_USB_PA11_PA12=y
CONFIG_WANT_TRAJECTORY=y
CONFIG_WANT_TRAJECTORY_PWM=y
CONFIG_WANT_TRAJECTORY_HIGHER_ORDER=y
CONFIG_WANT_SELF_TEST=y
CONFIG_ADC_PROFILE=y
