# NUCLEO-H723ZG authenticated Ethernet -> CAN-FD/serial Helix gateway.
#
# The Nucleo's LAN8742A RMII route uses PA1/PA2/PC1/PA7/PC4/PC5 plus
# PG11/PG13/PB13.  PB8/PB9 is the compile-time FDCAN route; verify the final
# mikroBUS/header wiring and TCAN1462 STB state before hardware qualification.
CONFIG_MACH_STM32=y
CONFIG_MACH_STM32H723=y
CONFIG_LOW_LEVEL_OPTIONS=y
CONFIG_STM32_CLOCK_REF_8M=y
CONFIG_STM32_FLASH_START_0000=y
CONFIG_STM32_ETHERNET_CAN_GATEWAY_RMII=y
CONFIG_STM32_CMENU_CANBUS_PB8_PB9=y
CONFIG_CANBUS_FREQUENCY=1000000
CONFIG_CANBUS_FD=y
CONFIG_CANBUS_DATA_FREQUENCY=8000000
CONFIG_CANBUS_TRANSCEIVER_MAX_DATA_RATE=8000000
CONFIG_RMII_TX_EN_PIN=107
CONFIG_RMII_TXD0_PIN=109
CONFIG_RMII_TXD1_PIN=29
CONFIG_RMII_PSK="ci-helix-gateway-pre-shared-key"
CONFIG_RMII_UDP_PORT=41415
CONFIG_WANT_DATAGRAM_SESSION=y
CONFIG_DATAGRAM_SESSION_ID="stm32h723-helix-gateway-ci"
CONFIG_DMA_POOL_SIZE=16384
